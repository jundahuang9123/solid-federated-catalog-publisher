@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .

<https://example.org/catalogs/publisher-demo> a dcat:Catalog ;
    dct:title "Publisher demo catalogue" ;
    dcat:dataset <https://example.org/datasets/demo-air> .

<https://example.org/datasets/demo-air> a dcat:Dataset ;
    dct:title "Demo air observations" ;
    dcat:distribution <https://example.org/datasets/demo-air/distribution> .

<https://example.org/datasets/demo-air/distribution> a dcat:Distribution ;
    dcat:downloadURL <https://example.org/data/demo-air.csv> ;
    dcat:mediaType "text/csv" .

