@prefix dcat: <http://www.w3.org/ns/dcat#> .
@prefix dct: <http://purl.org/dc/terms/> .
@prefix foaf: <http://xmlns.com/foaf/0.1/> .

<https://tmdt-solid-community-server.de/solidtestpod/catalog/cat.ttl>
    a dcat:Catalog ;
    dct:title "TMDT Solid test catalog" ;
    dct:publisher <https://tmdt-solid-community-server.de/solidtestpod/profile/card#me> ;
    dcat:contactPoint <https://tmdt-solid-community-server.de/solidtestpod/profile/card#me> ;
    dcat:dataset <https://tmdt-solid-community-server.de/solidtestpod/datasets/test-air-quality> .

<https://tmdt-solid-community-server.de/solidtestpod/profile/card#me>
    a foaf:Agent ;
    foaf:name "TMDT Solid test participant" .

<https://tmdt-solid-community-server.de/solidtestpod/datasets/test-air-quality>
    a dcat:Dataset ;
    dct:title "TMDT Solid test air quality dataset" ;
    dct:publisher <https://tmdt-solid-community-server.de/solidtestpod/profile/card#me> ;
    dcat:distribution <https://tmdt-solid-community-server.de/solidtestpod/datasets/test-air-quality/distribution/csv> .

<https://tmdt-solid-community-server.de/solidtestpod/datasets/test-air-quality/distribution/csv>
    a dcat:Distribution ;
    dcat:downloadURL <https://tmdt-solid-community-server.de/solidtestpod/data/test-air-quality.csv> ;
    dcat:mediaType "text/csv" .
